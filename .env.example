# Copia este archivo a .env y completa con tus credenciales reales.
# El archivo .env está gitignored, no se subirá al repo.

# === LLM para responder killer questions ===
# Solo necesitás UNA de las dos. OpenAI es lo que usás cuando hablás de "ChatGPT".

# OpenAI (recomendado, modelo gpt-4o-mini, ~$0.0001 por pregunta)
OPENAI_API_KEY=sk-tu-key-aqui

# Anthropic (alternativa, modelo Claude Haiku 4.5)
# ANTHROPIC_API_KEY=sk-ant-tu-key-aqui

# === Capsolver (resuelve Cloudflare Turnstile en HiringRoom) ===
# ~$0.001 por captcha. Crea cuenta en https://www.capsolver.com,
# cargá $1-5 USD, copiá el clientKey acá.
# CAPSOLVER_API_KEY=CAP-xxxxxxxxxxxx
